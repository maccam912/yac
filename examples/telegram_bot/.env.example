# Telegram Bot Token — get one from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# LLM backend — this example is pre-configured for OpenRouter
# with gpt-oss-120b, but any OpenAI-compatible API works.
#
# To use OpenRouter:
#   1. Sign up at https://openrouter.ai
#   2. Create an API key at https://openrouter.ai/keys
#   3. Paste it below
YAC_API_KEY=sk-or-v1-your-openrouter-key-here
YAC_BASE_URL=https://openrouter.ai/api/v1
YAC_MODEL=gpt-oss-120b

# Other provider examples:
#
# OpenAI:
#   YAC_API_KEY=sk-...
#   YAC_BASE_URL=https://api.openai.com/v1
#   YAC_MODEL=gpt-4o
#
# Local llama.cpp / Ollama:
#   YAC_API_KEY=not-needed
#   YAC_BASE_URL=http://localhost:8080/v1
#   YAC_MODEL=your-model-name

# Reminders — set a Vikunja project ID to enable set_reminder tool
# and automatic reminder polling. Requires VIKUNJA_URL and VIKUNJA_API_KEY
# in the root .env file.
# VIKUNJA_REMINDER_PROJECT_ID=1
